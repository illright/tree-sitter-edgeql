{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "edgeql",
      "camelcase": "EdgeQL",
      "title": "EdgeQL",
      "scope": "source.edgeql",
      "file-types": [
        "esdl",
        "edgeql",
        "gel"
      ],
      "injection-regex": "^edgeql$",
      "class-name": "TreeSitterEdgeql",
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPL-3.0",
    "description": "The query language for the Gel database (formerly known as EdgeDB)",
    "authors": [
      {
        "name": "illright",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/illright/tree-sitter-edgeql",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
